# Rendorix — image CDN signing credentials
#
# Local development:
#   Copy this file to `.env` and fill in your values.
#   `.env` is git-ignored and stays on your machine only.
#
# Cloudflare Pages (production):
#   Add these as build-time environment variables in:
#   Cloudflare Dashboard → Pages project → Settings → Environment variables
#   Use "Production" scope so they are available during `astro build`.

RENDORIX_BASE_URL=https://your-cloudfront-distribution.cloudfront.net
RENDORIX_SECRET=your-hmac-signing-secret
