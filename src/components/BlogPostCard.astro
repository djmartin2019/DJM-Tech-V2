---
import { ArrowRight } from 'lucide-astro';
import type { BlogPost } from '../data/blog';
import { imageUrl } from '../lib/rendorix-images';
import RendorixImage from './RendorixImage.astro';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<article class="blog-card">
  <a href={`/blog/${post.slug}`} class="blog-card-link">
    <div class="blog-card-image">
      <RendorixImage
        src={imageUrl(post.image, { preset: 'cardSquare' })}
        alt=""
        wrapClass="rx-image-wrap--fill"
        width={600}
        height={600}
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="blog-card-body">
      <p class="blog-card-meta">
        <time datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
        <span aria-hidden="true">·</span>
        <span>{post.readTime} min read</span>
      </p>
      <h3 class="blog-card-title">{post.title}</h3>
      <p class="blog-card-summary">{post.description}</p>
      <span class="blog-card-read-btn">
        Read now
        <ArrowRight class="h-4 w-4" aria-hidden="true" />
      </span>
    </div>
  </a>
</article>
