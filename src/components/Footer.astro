---
import { Code, Github, Linkedin, Mail } from 'lucide-astro';
---

<footer class="footer-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 gap-8">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-4 text-center md:text-left">
        <div class="flex items-center justify-center md:justify-start space-x-2 mb-4">
          <span class="text-xl font-bold neon-glow">David Martin</span>
        </div>
        <div class="flex justify-center md:justify-start space-x-4">
          <a href="https://github.com/djmartin2019" class="footer-link" aria-label="GitHub">
            <Github class="h-5 w-5" />
          </a>
          <a href="https://www.linkedin.com/in/davidjmartin2025" class="footer-link" aria-label="LinkedIn">
            <Linkedin class="h-5 w-5" />
          </a>
          <a href="mailto:djmartin2019@gmail.com" class="footer-link" aria-label="Email">
            <Mail class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>

    <div class="footer-divider mt-8 pt-8 text-center">
      <p class="footer-text">
        © 2026 David Martin
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-dark {
    background-color: #111111; /* Always dark */
    color: #e5e5e5; /* Always light text */
    border-top: 1px solid #2a2a2a; /* Always dark border */
  }
  
  .footer-heading {
    color: #e5e5e5; /* Always light text */
  }
  
  .footer-text {
    color: #a3a3a3; /* Always muted light text */
  }
  
  .footer-link {
    color: #a3a3a3; /* Always muted light text */
    transition: color 0.3s;
  }
  
  .footer-link:hover {
    color: #00d4ff; /* Always neon blue on hover */
  }
  
  .footer-divider {
    border-top: 1px solid #2a2a2a; /* Always dark border */
  }
</style>
