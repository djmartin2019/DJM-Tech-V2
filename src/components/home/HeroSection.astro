---
import { rx } from '../../lib/rendorix';

const headshotUrl = rx.img('about-me-photo.jpeg', { preset: 'headshot' });
---

<section class="relative home-hero py-16 lg:py-28 overflow-hidden" aria-labelledby="hero-heading">
  <div class="home-hero-grid" aria-hidden="true"></div>
  <div class="home-hero-glow" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="space-y-6 text-center lg:text-left">
        <p class="home-hero-name">David Martin</p>
        <h1 id="hero-heading" class="home-hero-heading text-4xl sm:text-5xl lg:text-[3.25rem] text-balance">
          <span class="home-hero-role">Backend & Platform Engineer</span>
        </h1>
        <p class="home-hero-sub text-lg mx-auto lg:mx-0 text-balance">
          I build operational software, developer infrastructure, and scalable backend systems using TypeScript, Postgres, Docker, and cloud platforms.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2">
          <a href="/projects" class="home-btn-primary">View Projects</a>
          <a href="/blog" class="home-btn-secondary">Read Technical Writing</a>
        </div>
      </div>

      <div class="flex flex-col gap-5 items-center lg:items-end">
        <div class="hidden sm:block home-portrait-ring">
          <img
            src={headshotUrl}
            alt="David Martin"
            class="home-portrait"
            width="320"
            height="320"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>
