---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { User, Monitor, Server, Wrench, Zap, Shield, Users, BookOpen, Mail, Check } from 'lucide-astro';
---

<Layout title="About - DJM Tech" description="Learn about David Martin's shift into infrastructure and platform engineering, and how DJM Tech is becoming a practical environment for launching apps fast.">
  <Header />

  <!-- Creator Section -->
  <section class="pt-12 pb-20 lg:pt-16 lg:pb-24 creator-bg relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Portrait -->
        <div class="relative flex justify-center lg:justify-start">
          <div class="relative portrait-container">
            <div class="portrait-glow"></div>
            <img 
              src="/assets/about-me-photo.jpeg" 
              alt="David Martin - Platform and Infrastructure Engineer behind DJM Tech"
              class="portrait-image"
            />
            <div class="absolute inset-0 portrait-border"></div>
          </div>
        </div>

        <!-- Intro Text -->
        <div class="space-y-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold creator-title mb-4">
              Hey, I'm David
            </h2>
            <p class="text-xl md:text-2xl creator-subtitle mb-6">
              I build infrastructure and platform systems that help teams ship faster.
            </p>
          </div>
          
          <div class="space-y-4">
            <p class="creator-text">
              I am deeply curious about how software is hosted, deployed, and operated in production. My VPS is my live lab for turning those ideas into repeatable, real workflows.
            </p>
            <p class="creator-text">
              In a world full of builders, I want to be the engineer who helps other builders go live fast.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 lg:py-24 section-bg relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00d4ff]/30 to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold section-title mb-4">The Story</h2>
        <p class="text-lg section-subtitle">How my focus evolved</p>
      </div>
      
      <div class="space-y-6">
        <p class="text-lg md:text-xl story-text leading-relaxed">
          DJM Tech started as a personal portfolio, but the deeper interest quickly became infrastructure: <strong>what it takes to take software from code to live production.</strong>
        </p>
        
        <p class="text-lg md:text-xl story-text leading-relaxed">
          I am now building DJM Tech into a practical platform engineering environment on my VPS. It already hosts PHP applications, and I am expanding to support multiple stacks with isolated Docker-based deployments.
        </p>
        
        <p class="text-lg md:text-xl story-text leading-relaxed">
          The philosophy is simple: <strong>reliability, repeatability, and fast launch velocity.</strong> Build clean systems, remove deployment friction, and help ideas reach production faster.
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 lg:py-24 skills-bg relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00d4ff]/30 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold section-title mb-4">Platform Principles</h2>
        <p class="text-lg section-subtitle">What guides my engineering decisions</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Zap class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Launch Velocity</h3>
          <p class="value-description">Shorten the path from idea to production without sacrificing quality.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Shield class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Reliability</h3>
          <p class="value-description">Stable deployments and predictable operations come before hype.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Users class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Developer Enablement</h3>
          <p class="value-description">Build platforms that make it easier for others to ship confidently.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <BookOpen class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Platform Thinking</h3>
          <p class="value-description">Design infrastructure as a product, not a one-off setup.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- CTA Section -->
  <section class="py-20 cta-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold cta-title mb-4">Need to Ship Faster?</h2>
      <p class="text-xl cta-subtitle mb-8 max-w-2xl mx-auto">
        If you are building products and want better hosting and deployment workflows, let's talk platform and infrastructure.
      </p>
      <a href="/contact" class="bg-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors inline-flex items-center">
        <Mail class="h-5 w-5 mr-2" />
        Get In Touch
      </a>
    </div>
  </section>

  <Footer />

  <style>
    .hero-bg {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
      position: relative;
    }

    html.light .hero-bg {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .hero-bg-elements {
      pointer-events: none;
    }

    .hero-bg-gradient {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.05) 0%, transparent 50%),
                  radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
    }

    .hero-bg-pattern {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
      background-size: 20px 20px;
      opacity: 0.2;
    }

    .hero-title {
      color: var(--text-primary);
    }

    html.light .hero-title {
      color: #0f172a;
      font-weight: 700;
    }

    .hero-subtitle {
      color: var(--text-secondary);
    }

    html.light .hero-subtitle {
      color: #475569;
      font-weight: 500;
    }

    /* Creator Section */
    .creator-bg {
      background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      position: relative;
    }

    .creator-bg::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 80% 50%, rgba(0, 212, 255, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .portrait-container {
      position: relative;
      width: 100%;
      max-width: 400px;
    }

    .portrait-glow {
      position: absolute;
      inset: -20px;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.4) 0%, rgba(0, 212, 255, 0.1) 40%, transparent 70%);
      border-radius: 50%;
      filter: blur(30px);
      animation: pulse-glow 3s ease-in-out infinite;
      z-index: 0;
    }

    @keyframes pulse-glow {
      0%, 100% {
        opacity: 0.6;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    .portrait-image {
      position: relative;
      width: 100%;
      height: auto;
      border-radius: 1rem;
      border: 2px solid rgba(0, 212, 255, 0.3);
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.3), 0 0 80px rgba(0, 212, 255, 0.2);
      z-index: 1;
      transition: transform 0.3s ease;
    }

    .portrait-image:hover {
      transform: scale(1.02);
      box-shadow: 0 0 60px rgba(0, 212, 255, 0.4), 0 0 120px rgba(0, 212, 255, 0.3);
    }

    .portrait-border {
      border-radius: 1rem;
      border: 1px solid rgba(0, 212, 255, 0.2);
      pointer-events: none;
      z-index: 2;
    }

    .creator-title {
      color: var(--text-primary);
    }

    .creator-subtitle {
      color: var(--text-secondary);
    }

    .creator-text {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    html.light .creator-bg {
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    html.light .portrait-glow {
      background: radial-gradient(circle, rgba(0, 212, 255, 0.2) 0%, rgba(0, 212, 255, 0.05) 40%, transparent 70%);
    }

    html.light .portrait-image {
      border-color: rgba(0, 212, 255, 0.4);
      box-shadow: 0 0 30px rgba(0, 212, 255, 0.2), 0 0 60px rgba(0, 212, 255, 0.1);
    }

    html.light .portrait-image:hover {
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.3), 0 0 80px rgba(0, 212, 255, 0.2);
    }

    .section-bg {
      background-color: var(--bg-secondary);
      position: relative;
    }

    .section-title {
      color: var(--text-primary);
    }

    .section-subtitle {
      color: var(--text-secondary);
    }

    .story-text {
      color: var(--text-secondary);
    }

    .story-text strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    html.light .section-bg {
      background-color: #f8fafc;
    }

    html.light .skills-bg {
      background-color: #ffffff;
    }

    .skills-bg {
      background-color: var(--bg-primary);
    }

    .skill-icon {
      color: var(--accent-color);
    }

    .skill-title {
      color: var(--text-primary);
    }

    .skill-item {
      color: var(--text-secondary);
    }

    .value-icon-container {
      background-color: rgba(0, 212, 255, 0.2);
      border: 2px solid var(--accent-color);
    }

    .value-icon {
      color: var(--accent-color);
    }

    .value-title {
      color: var(--text-primary);
    }

    .value-description {
      color: var(--text-secondary);
    }

    .cta-bg {
      background: linear-gradient(135deg, var(--accent-color) 0%, var(--accent-dark) 100%);
    }

    .cta-title {
      color: var(--bg-primary);
    }

    .cta-subtitle {
      color: rgba(255, 255, 255, 0.9);
    }

    /* CTA Buttons */
    .primary-cta-button {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #0a0a0a;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 8px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.2);
      border: none;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .primary-cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.4), 0 0 20px rgba(0, 212, 255, 0.3);
      background: linear-gradient(135deg, #33dfff 0%, #00d4ff 100%);
    }

    .secondary-cta-button {
      background-color: transparent;
      color: #00d4ff;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      border: 2px solid #00d4ff;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #0a0a0a;
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.3), 0 0 20px rgba(0, 212, 255, 0.2);
    }

    html.light .secondary-cta-button {
      color: #00d4ff;
      border-color: #00d4ff;
    }

    html.light .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #ffffff;
    }
  </style>
</Layout>
