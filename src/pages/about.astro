---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Zap, Shield, Users, BookOpen, Mail, Layers } from 'lucide-astro';
import { rx } from '../lib/rendorix';
import RendorixImage from '../components/RendorixImage.astro';

const headshotUrl = rx.img('about-me-photo.jpeg', { preset: 'headshotAbout' });

const stackGroups = [
  {
    title: 'Backend & Apps',
    items: ['TypeScript', 'Node.js', 'Next.js', 'Prisma'],
  },
  {
    title: 'Data & APIs',
    items: ['PostgreSQL', 'REST APIs', 'WebSockets'],
  },
  {
    title: 'Infrastructure',
    items: ['Docker', 'Apache', 'Cloudflare', 'VPS'],
  },
];
---

<Layout
  title="About | David Martin - Backend & Platform Engineer"
  description="Backend and platform engineer focused on operational software, observability, infrastructure, and TypeScript systems in production."
>
  <Header />

  <!-- Creator Section -->
  <section class="pt-12 pb-20 lg:pt-16 lg:pb-24 creator-bg relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Portrait -->
        <div class="relative flex justify-center lg:justify-start">
          <div class="portrait-container">
            <div class="portrait-glow" aria-hidden="true"></div>
            <div class="portrait-ring">
              <RendorixImage
                src={headshotUrl}
                alt="David Martin"
                class="portrait-image"
                wrapClass="rx-image-wrap--fill"
                width={960}
                height={960}
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </div>
          </div>
        </div>

        <!-- Intro Text -->
        <div class="space-y-6">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold creator-title mb-4 text-balance">
              Hi, I'm David!
            </h1>
            <p class="text-xl md:text-2xl creator-subtitle mb-6 text-balance">
              I build operational software, developer infrastructure, and scalable backend systems using TypeScript, Postgres, Docker, and cloud platforms.
            </p>
          </div>

          <div class="space-y-4">
            <p class="creator-text">
              I care about how software behaves in production, not just how it looks in a demo. My background includes platform-facing customer work at Vercel, where I helped customers troubleshoot deployments, routing, DNS, environment configuration, and the kinds of operational issues that appear once real systems are live.
            </p>
            <p class="creator-text">
              Alongside that experience, I’ve spent years building and self-hosting projects focused on observability, telemetry, infrastructure, and backend architecture. I’m especially interested in the operational layers that keep systems reliable as complexity, traffic, and data scale.
            </p>
            <p class="creator-text">
              Today I focus on backend architecture, observability, telemetry, and the operational layers that keep systems reliable as data and traffic grow. Explore my <a href="/projects" class="creator-link">projects</a>, <a href="/blog" class="creator-link">technical writing</a>, or <a href="https://github.com/djmartin2019" target="_blank" rel="noopener noreferrer" class="creator-link">GitHub</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="about-stack-section" aria-labelledby="about-stack-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="about-stack-panel">
        <div class="about-stack-header">
          <div class="about-stack-header-icon" aria-hidden="true">
            <Layers class="h-5 w-5" />
          </div>
          <div>
            <p class="about-stack-eyebrow">Stack</p>
            <h2 id="about-stack-heading" class="about-stack-title">What I build with</h2>
            <p class="about-stack-lead">
              TypeScript-first backends and operational tooling, from the database layer through Dockerized deployment on Cloudflare and my VPS.
            </p>
          </div>
        </div>

        <div class="about-stack-grid">
          {stackGroups.map((group) => (
            <div class="about-stack-card">
              <h3 class="about-stack-card-title">{group.title}</h3>
              <ul class="about-stack-badges" role="list">
                {group.items.map((item) => (
                  <li>
                    <span class="about-stack-badge">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 lg:py-24 skills-bg relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00d4ff]/30 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold section-title mb-4">Engineering Principles</h2>
        <p class="text-lg section-subtitle">What guides my engineering decisions</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Shield class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Production first</h3>
          <p class="value-description">Design for how systems behave under real traffic, auth, and failure modes after launch.</p>
        </div>

        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Zap class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Observability</h3>
          <p class="value-description">Metrics, health checks, and telemetry that tell operators what is actually happening.</p>
        </div>

        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Users class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Ownership</h3>
          <p class="value-description">Own architecture through deployment: data layer, APIs, proxies, and the ops around them.</p>
        </div>

        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <BookOpen class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Systems thinking</h3>
          <p class="value-description">Query patterns, caching, and infrastructure choices that determine whether scale holds.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- CTA Section -->
  <section class="py-20 cta-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold cta-title mb-4">Get in touch</h2>
      <p class="text-xl cta-subtitle mb-8 max-w-2xl mx-auto text-balance">
        Open to backend and platform engineering conversations, whether you are hiring or want to talk through systems you are building.
      </p>
      <a href="/contact" class="about-cta-button inline-flex items-center">
        <Mail class="h-5 w-5 mr-2" aria-hidden="true" />
        Get In Touch
      </a>
    </div>
  </section>

  <Footer />

  <style>
    .hero-bg {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
      position: relative;
    }

    html.light .hero-bg {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .hero-bg-elements {
      pointer-events: none;
    }

    .hero-bg-gradient {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.05) 0%, transparent 50%),
                  radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
    }

    .hero-bg-pattern {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
      background-size: 20px 20px;
      opacity: 0.2;
    }

    .hero-title {
      color: var(--text-primary);
    }

    html.light .hero-title {
      color: #0f172a;
      font-weight: 700;
    }

    .hero-subtitle {
      color: var(--text-secondary);
    }

    html.light .hero-subtitle {
      color: #475569;
      font-weight: 500;
    }

    /* Creator Section */
    .creator-bg {
      background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      position: relative;
    }

    .creator-bg::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 80% 50%, rgba(0, 212, 255, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .portrait-container {
      position: relative;
      width: 100%;
      max-width: min(100%, 28rem);
      aspect-ratio: 1 / 1;
    }

    .portrait-glow {
      position: absolute;
      inset: -20px;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.4) 0%, rgba(0, 212, 255, 0.1) 40%, transparent 70%);
      border-radius: 50%;
      filter: blur(30px);
      animation: pulse-glow 3s ease-in-out infinite;
      z-index: 0;
    }

    @keyframes pulse-glow {
      0%, 100% {
        opacity: 0.6;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    .portrait-ring {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      border-radius: 0.85rem;
      padding: 3px;
      background: linear-gradient(
        135deg,
        rgba(0, 212, 255, 0.55) 0%,
        rgba(0, 212, 255, 0.12) 50%,
        rgba(0, 212, 255, 0.4) 100%
      );
      box-shadow:
        0 0 0 1px rgba(0, 212, 255, 0.12),
        0 0 32px rgba(0, 212, 255, 0.2);
    }

    .portrait-image {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 0.75rem;
      object-fit: cover;
      object-position: center top;
      transition: transform 0.3s ease;
    }

    .portrait-ring:hover .portrait-image {
      transform: scale(1.02);
    }

    .creator-eyebrow {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }

    html.light .creator-eyebrow {
      color: #0077a8;
    }

    .creator-title {
      color: var(--text-primary);
    }

    .creator-subtitle {
      color: var(--text-secondary);
    }

    .creator-text {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Tech stack */
    .about-stack-section {
      padding: 3rem 0 4rem;
      position: relative;
    }

    .about-stack-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(0, 212, 255, 0.35) 50%,
        transparent 100%
      );
    }

    .about-stack-panel {
      background: var(--bg-card);
      border: 1px solid rgba(0, 212, 255, 0.22);
      border-radius: 1rem;
      padding: 1.75rem 1.5rem;
      box-shadow:
        0 0 0 1px rgba(0, 212, 255, 0.06),
        0 16px 40px rgba(0, 0, 0, 0.35);
    }

    html.light .about-stack-panel {
      background: #ffffff;
      border-color: rgba(0, 119, 168, 0.25);
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }

    .about-stack-header {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.75rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
    }

    .about-stack-header-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 0.65rem;
      background: rgba(0, 212, 255, 0.1);
      border: 1px solid rgba(0, 212, 255, 0.28);
      color: var(--accent-color);
    }

    .about-stack-eyebrow {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent-color);
      margin-bottom: 0.35rem;
    }

    .about-stack-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .about-stack-lead {
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--text-secondary);
      max-width: 40rem;
      margin: 0;
    }

    .about-stack-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    @media (min-width: 640px) {
      .about-stack-panel {
        padding: 2rem 2rem 2.25rem;
      }

      .about-stack-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .about-stack-card {
      background: rgba(0, 0, 0, 0.22);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.15rem 1.2rem 1.25rem;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .about-stack-card:hover {
      border-color: rgba(0, 212, 255, 0.35);
      transform: translateY(-2px);
    }

    html.light .about-stack-card {
      background: #f8fafc;
      border-color: #e2e8f0;
    }

    .about-stack-card-title {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent-color);
      margin-bottom: 0.85rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }

    .about-stack-badges {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .about-stack-badges li {
      margin: 0;
    }

    .about-stack-badge {
      display: block;
      width: 100%;
      text-align: left;
      padding: 0.45rem 0.75rem;
      border-radius: 0.45rem;
      font-size: 0.85rem;
      font-weight: 500;
      background: rgba(0, 212, 255, 0.06);
      border: 1px solid rgba(0, 212, 255, 0.18);
      color: var(--text-primary);
      transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }

    .about-stack-badge:hover {
      background: rgba(0, 212, 255, 0.12);
      border-color: rgba(0, 212, 255, 0.4);
      color: var(--accent-color);
    }

    html.light .about-stack-eyebrow,
    html.light .about-stack-card-title {
      color: #0077a8;
    }

    html.light .about-stack-title {
      color: #0f172a;
    }

    html.light .about-stack-lead {
      color: #475569;
    }

    html.light .about-stack-badge {
      background: rgba(0, 212, 255, 0.06);
      border-color: rgba(0, 119, 168, 0.2);
      color: #0f172a;
    }

    html.light .about-stack-badge:hover {
      color: #0077a8;
    }

    .creator-link {
      color: #00d4ff;
      text-decoration: none;
      border-bottom: 1px solid rgba(0, 212, 255, 0.35);
      transition: border-color 0.2s ease;
    }

    .creator-link:hover {
      border-color: #00d4ff;
    }

    html.light .creator-link {
      color: #0077a8;
      border-bottom-color: rgba(0, 119, 168, 0.35);
    }

    html.light .creator-link:hover {
      border-bottom-color: #0077a8;
    }

    html.light .creator-bg {
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    html.light .portrait-glow {
      background: radial-gradient(circle, rgba(0, 212, 255, 0.2) 0%, rgba(0, 212, 255, 0.05) 40%, transparent 70%);
    }

    html.light .portrait-ring {
      background: linear-gradient(
        135deg,
        rgba(0, 153, 204, 0.75) 0%,
        rgba(0, 153, 204, 0.2) 50%,
        rgba(0, 153, 204, 0.55) 100%
      );
    }

    .about-cta-button {
      background-color: #0a0a0a;
      color: #ffffff;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.05rem;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    }

    .about-cta-button:hover {
      background-color: #141414;
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    }

    html.light .about-cta-button {
      background-color: #ffffff;
      color: #0f172a;
      box-shadow: 0 4px 14px rgba(15, 23, 42, 0.15);
    }

    html.light .about-cta-button:hover {
      background-color: #f8fafc;
    }

    .section-bg {
      background-color: var(--bg-secondary);
      position: relative;
    }

    .section-title {
      color: var(--text-primary);
    }

    .section-subtitle {
      color: var(--text-secondary);
    }

    .story-text {
      color: var(--text-secondary);
    }

    .story-text strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    html.light .section-bg {
      background-color: #f8fafc;
    }

    html.light .skills-bg {
      background-color: #ffffff;
    }

    .skills-bg {
      background-color: var(--bg-primary);
    }

    .skill-icon {
      color: var(--accent-color);
    }

    .skill-title {
      color: var(--text-primary);
    }

    .skill-item {
      color: var(--text-secondary);
    }

    .value-icon-container {
      background-color: rgba(0, 212, 255, 0.2);
      border: 2px solid var(--accent-color);
    }

    .value-icon {
      color: var(--accent-color);
    }

    .value-title {
      color: var(--text-primary);
    }

    .value-description {
      color: var(--text-secondary);
    }

    .cta-bg {
      background: linear-gradient(135deg, var(--accent-color) 0%, var(--accent-dark) 100%);
    }

    .cta-title {
      color: var(--bg-primary);
    }

    .cta-subtitle {
      color: rgba(255, 255, 255, 0.9);
    }

    /* CTA Buttons */
    .primary-cta-button {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #0a0a0a;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 8px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.2);
      border: none;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .primary-cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.4), 0 0 20px rgba(0, 212, 255, 0.3);
      background: linear-gradient(135deg, #33dfff 0%, #00d4ff 100%);
    }

    .secondary-cta-button {
      background-color: transparent;
      color: #00d4ff;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      border: 2px solid #00d4ff;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #0a0a0a;
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.3), 0 0 20px rgba(0, 212, 255, 0.2);
    }

    html.light .secondary-cta-button {
      color: #00d4ff;
      border-color: #00d4ff;
    }

    html.light .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #ffffff;
    }
  </style>
</Layout>
