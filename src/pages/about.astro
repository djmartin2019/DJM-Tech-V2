---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { User, Monitor, Server, Wrench, Zap, Shield, Users, BookOpen, Mail, Check } from 'lucide-astro';
---

<Layout title="About - DJM Tech" description="David Martin is a full-stack web developer and freelance engineer who builds production-grade websites, web apps, and backend systems.">
  <Header />

  <!-- Creator Section -->
  <section class="pt-12 pb-20 lg:pt-16 lg:pb-24 creator-bg relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Portrait -->
        <div class="relative flex justify-center lg:justify-start">
          <div class="relative portrait-container">
            <div class="portrait-glow"></div>
            <img 
              src="/assets/about-me-photo.jpeg" 
              alt="David Martin - Web Developer and Freelance Engineer"
              class="portrait-image"
            />
            <div class="absolute inset-0 portrait-border"></div>
          </div>
        </div>

        <!-- Intro Text -->
        <div class="space-y-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold creator-title mb-4">
              Hey, I'm David
            </h2>
            <p class="text-xl md:text-2xl creator-subtitle mb-6">
              I build websites, web applications, and the backend systems that power them.
            </p>
          </div>
          
          <div class="space-y-4">
            <p class="creator-text">
              I work across the full stack: frontend interfaces, APIs, databases, and deployment. I hold my work to a high engineering standard and own the entire lifecycle from architecture to launch.
            </p>
            <p class="creator-text">
              I'm available for freelance projects and deliver working software to real clients. I'm also open to full-time engineering roles. If you're hiring, take a look at my <a href="https://github.com/djmartin2019" target="_blank" rel="noopener noreferrer" class="creator-link">GitHub</a> and <a href="/projects" class="creator-link">projects</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-10 tech-stack-section">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest tech-stack-eyebrow mb-6">Tech I work with</p>
      <div class="space-y-4">
        <div class="flex flex-wrap items-center gap-2">
          <span class="about-stack-label">Websites & Apps</span>
          <span class="about-stack-badge">React</span>
          <span class="about-stack-badge">TypeScript</span>
          <span class="about-stack-badge">Node.js</span>
          <span class="about-stack-badge">Astro</span>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="about-stack-label">Backend Systems</span>
          <span class="about-stack-badge">Python</span>
          <span class="about-stack-badge">PostgreSQL</span>
          <span class="about-stack-badge">REST APIs</span>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="about-stack-label">Hosting & Deployment</span>
          <span class="about-stack-badge">Docker</span>
          <span class="about-stack-badge">Cloudflare</span>
          <span class="about-stack-badge">VPS</span>
          <span class="about-stack-badge">GitHub Actions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 lg:py-24 section-bg relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00d4ff]/30 to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold section-title mb-4">The Story</h2>
        <p class="text-lg section-subtitle">What DJM Tech is and why it exists</p>
      </div>
      
      <div class="space-y-6">
        <p class="text-lg md:text-xl story-text leading-relaxed">
          DJM Tech is my development practice. I build <strong>websites, web applications, and backend systems</strong> for clients and for my own products and I take every project from architecture through deployment.
        </p>
        
        <p class="text-lg md:text-xl story-text leading-relaxed">
          I also operate my own multi-stack hosting environment on a VPS with isolated Docker containers. That infrastructure work isn't the headline it's <strong>proof that I understand the full lifecycle</strong> of how software gets built, shipped, and kept running.
        </p>
        
        <p class="text-lg md:text-xl story-text leading-relaxed">
          The philosophy is simple: <strong>write clean code, deliver reliable software, and ship fast.</strong> Every project gets the same standard of engineering discipline regardless of size.
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 lg:py-24 skills-bg relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00d4ff]/30 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold section-title mb-4">Engineering Principles</h2>
        <p class="text-lg section-subtitle">What guides my engineering decisions</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Zap class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Launch Velocity</h3>
          <p class="value-description">Shorten the path from idea to production without sacrificing quality.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Shield class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Reliability</h3>
          <p class="value-description">Stable deployments and predictable operations come before hype.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <Users class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Ownership</h3>
          <p class="value-description">Take the whole problem, not just your piece of it. Don't hand off half-finished work.</p>
        </div>
        
        <div class="text-center">
          <div class="value-icon-container rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <BookOpen class="h-8 w-8 value-icon" />
          </div>
          <h3 class="text-lg font-semibold value-title mb-2">Systems Thinking</h3>
          <p class="value-description">Understand the full picture from database to deployment, not just your piece of it.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- CTA Section -->
  <section class="py-20 cta-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold cta-title mb-4">Let's Work Together</h2>
      <p class="text-xl cta-subtitle mb-8 max-w-2xl mx-auto">
        Whether you need a website built, a broken project rescued, or you're looking to bring on an engineer, I'd like to hear about it.
      </p>
      <a href="/contact" class="bg-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors inline-flex items-center">
        <Mail class="h-5 w-5 mr-2" />
        Get In Touch
      </a>
    </div>
  </section>

  <Footer />

  <style>
    .hero-bg {
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
      position: relative;
    }

    html.light .hero-bg {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .hero-bg-elements {
      pointer-events: none;
    }

    .hero-bg-gradient {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.05) 0%, transparent 50%),
                  radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
    }

    .hero-bg-pattern {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
      background-size: 20px 20px;
      opacity: 0.2;
    }

    .hero-title {
      color: var(--text-primary);
    }

    html.light .hero-title {
      color: #0f172a;
      font-weight: 700;
    }

    .hero-subtitle {
      color: var(--text-secondary);
    }

    html.light .hero-subtitle {
      color: #475569;
      font-weight: 500;
    }

    /* Creator Section */
    .creator-bg {
      background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      position: relative;
    }

    .creator-bg::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 80% 50%, rgba(0, 212, 255, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .portrait-container {
      position: relative;
      width: 100%;
      max-width: 400px;
    }

    .portrait-glow {
      position: absolute;
      inset: -20px;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.4) 0%, rgba(0, 212, 255, 0.1) 40%, transparent 70%);
      border-radius: 50%;
      filter: blur(30px);
      animation: pulse-glow 3s ease-in-out infinite;
      z-index: 0;
    }

    @keyframes pulse-glow {
      0%, 100% {
        opacity: 0.6;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.05);
      }
    }

    .portrait-image {
      position: relative;
      width: 100%;
      height: auto;
      border-radius: 1rem;
      border: 2px solid rgba(0, 212, 255, 0.3);
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.3), 0 0 80px rgba(0, 212, 255, 0.2);
      z-index: 1;
      transition: transform 0.3s ease;
    }

    .portrait-image:hover {
      transform: scale(1.02);
      box-shadow: 0 0 60px rgba(0, 212, 255, 0.4), 0 0 120px rgba(0, 212, 255, 0.3);
    }

    .portrait-border {
      border-radius: 1rem;
      border: 1px solid rgba(0, 212, 255, 0.2);
      pointer-events: none;
      z-index: 2;
    }

    .creator-title {
      color: var(--text-primary);
    }

    .creator-subtitle {
      color: var(--text-secondary);
    }

    .creator-text {
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Tech Stack Section */
    .tech-stack-section {
      background-color: var(--bg-secondary);
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
    }

    .tech-stack-eyebrow {
      color: #00d4ff;
      opacity: 0.8;
    }

    .about-stack-label {
      color: var(--text-secondary);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      white-space: nowrap;
      min-width: 9rem;
      opacity: 0.65;
    }

    .about-stack-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 500;
      background: rgba(0, 212, 255, 0.06);
      border: 1px solid rgba(0, 212, 255, 0.2);
      color: var(--text-secondary);
      letter-spacing: 0.01em;
      transition: all 0.2s ease;
    }

    .about-stack-badge:hover {
      background: rgba(0, 212, 255, 0.12);
      border-color: rgba(0, 212, 255, 0.4);
      color: #00d4ff;
    }

    html.light .tech-stack-section {
      background-color: var(--bg-secondary);
      border-color: #e2e8f0;
    }

    html.light .tech-stack-eyebrow {
      color: #0077a8;
      opacity: 1;
    }

    html.light .about-stack-label {
      color: #475569;
    }

    html.light .about-stack-badge {
      background: rgba(0, 212, 255, 0.07);
      border-color: rgba(0, 212, 255, 0.22);
      color: #334155;
    }

    html.light .about-stack-badge:hover {
      background: rgba(0, 212, 255, 0.14);
      border-color: rgba(0, 212, 255, 0.4);
      color: #0077a8;
    }

    .creator-link {
      color: #00d4ff;
      text-decoration: none;
      border-bottom: 1px solid rgba(0, 212, 255, 0.35);
      transition: border-color 0.2s ease;
    }

    .creator-link:hover {
      border-color: #00d4ff;
    }

    html.light .creator-link {
      color: #0077a8;
      border-bottom-color: rgba(0, 119, 168, 0.35);
    }

    html.light .creator-link:hover {
      border-bottom-color: #0077a8;
    }

    html.light .creator-bg {
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    html.light .portrait-glow {
      background: radial-gradient(circle, rgba(0, 212, 255, 0.2) 0%, rgba(0, 212, 255, 0.05) 40%, transparent 70%);
    }

    html.light .portrait-image {
      border-color: rgba(0, 212, 255, 0.4);
      box-shadow: 0 0 30px rgba(0, 212, 255, 0.2), 0 0 60px rgba(0, 212, 255, 0.1);
    }

    html.light .portrait-image:hover {
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.3), 0 0 80px rgba(0, 212, 255, 0.2);
    }

    .section-bg {
      background-color: var(--bg-secondary);
      position: relative;
    }

    .section-title {
      color: var(--text-primary);
    }

    .section-subtitle {
      color: var(--text-secondary);
    }

    .story-text {
      color: var(--text-secondary);
    }

    .story-text strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    html.light .section-bg {
      background-color: #f8fafc;
    }

    html.light .skills-bg {
      background-color: #ffffff;
    }

    .skills-bg {
      background-color: var(--bg-primary);
    }

    .skill-icon {
      color: var(--accent-color);
    }

    .skill-title {
      color: var(--text-primary);
    }

    .skill-item {
      color: var(--text-secondary);
    }

    .value-icon-container {
      background-color: rgba(0, 212, 255, 0.2);
      border: 2px solid var(--accent-color);
    }

    .value-icon {
      color: var(--accent-color);
    }

    .value-title {
      color: var(--text-primary);
    }

    .value-description {
      color: var(--text-secondary);
    }

    .cta-bg {
      background: linear-gradient(135deg, var(--accent-color) 0%, var(--accent-dark) 100%);
    }

    .cta-title {
      color: var(--bg-primary);
    }

    .cta-subtitle {
      color: rgba(255, 255, 255, 0.9);
    }

    /* CTA Buttons */
    .primary-cta-button {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #0a0a0a;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      box-shadow: 0 4px 8px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.2);
      border: none;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .primary-cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.4), 0 0 20px rgba(0, 212, 255, 0.3);
      background: linear-gradient(135deg, #33dfff 0%, #00d4ff 100%);
    }

    .secondary-cta-button {
      background-color: transparent;
      color: #00d4ff;
      padding: 1rem 2rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      border: 2px solid #00d4ff;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
      cursor: pointer;
      pointer-events: auto;
      position: relative;
      z-index: 10;
    }

    .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #0a0a0a;
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0, 212, 255, 0.3), 0 0 20px rgba(0, 212, 255, 0.2);
    }

    html.light .secondary-cta-button {
      color: #00d4ff;
      border-color: #00d4ff;
    }

    html.light .secondary-cta-button:hover {
      background-color: #00d4ff;
      color: #ffffff;
    }
  </style>
</Layout>
