---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { Code, Folder, Star, ExternalLink, Github } from 'lucide-astro';
import { getFeaturedProjects } from '../data/projects';
import { getRecentPosts } from '../data/blog';

const featuredProjects = getFeaturedProjects();
const recentPosts = await getRecentPosts(3);
---

<Layout title="David Martin - Full Stack Developer & Freelance Engineer">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative hero-bg py-20 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div class="space-y-8 text-center lg:text-left">
          <!-- Main Heading -->
          <h1 class="text-5xl md:text-6xl font-bold hero-title leading-tight">
            David Martin <br />
            <span class="neon-glow">I Build Websites That Work</span>
          </h1>
          
          <!-- Description -->
          <p class="text-xl hero-subtitle max-w-2xl lg:max-w-none mx-auto lg:mx-0">
            Websites and web apps that keep working after launch. No broken handoffs, no mystery technical debt. I handle everything so you don't have to.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/contact" class="primary-cta-button">
              Work With Me
            </a>
            <a href="/projects" class="secondary-cta-button">
              View Projects
            </a>
          </div>

          <!-- Capability Stack -->
          <div class="pt-2 space-y-3">
            <div class="flex flex-wrap items-center gap-2 justify-center lg:justify-start">
              <span class="tech-stack-label">Web Apps</span>
              <span class="tech-hero-badge">React</span>
              <span class="tech-hero-badge">TypeScript</span>
              <span class="tech-hero-badge">Node.js</span>
            </div>
            <div class="flex flex-wrap items-center gap-2 justify-center lg:justify-start">
              <span class="tech-stack-label">Backend & Data</span>
              <span class="tech-hero-badge">Python</span>
              <span class="tech-hero-badge">PostgreSQL</span>
            </div>
            <div class="flex flex-wrap items-center gap-2 justify-center lg:justify-start">
              <span class="tech-stack-label">Deploy & Infra</span>
              <span class="tech-hero-badge">Docker</span>
              <span class="tech-hero-badge">Cloudflare</span>
              <span class="tech-hero-badge">VPS</span>
            </div>
          </div>
        </div>
        
        <!-- Right Content - Image -->
        <div class="relative hidden lg:block">
          <div class="hero-image-container">
            <img 
              src="/assets/djm-image.png" 
              alt="David Martin - Full Stack Developer & Freelance Engineer" 
              class="hero-image"
            />
            <div class="hero-image-glow"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Background Elements -->
    <div class="absolute inset-0 hero-bg-elements">
      <div class="hero-bg-gradient"></div>
      <div class="hero-bg-pattern"></div>
    </div>
  </section>

  <!-- Bridge: What This Actually Means -->
  <section class="py-20 bridge-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="bridge-eyebrow">What this actually means</span>
        <h2 class="text-3xl md:text-4xl font-bold bridge-title mt-3 mb-4">More Than Just a Website</h2>
        <p class="text-lg bridge-subtitle max-w-2xl mx-auto">
          A lot of developers build something, hand it over, and disappear. Here's what you actually get when you work with me.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bridge-item">
          <span class="bridge-item-icon">&#x2714;</span>
          <div>
            <strong class="bridge-item-title">It works after launch</strong>
            <p class="bridge-item-desc">Not just in the demo. I test against real conditions so you're not discovering problems after you go live.</p>
          </div>
        </div>
        <div class="bridge-item">
          <span class="bridge-item-icon">&#x2714;</span>
          <div>
            <strong class="bridge-item-title">You can update it yourself</strong>
            <p class="bridge-item-desc">I build sites so the people who own them can make changes without calling a developer every time.</p>
          </div>
        </div>
        <div class="bridge-item">
          <span class="bridge-item-icon">&#x2714;</span>
          <div>
            <strong class="bridge-item-title">Domain, security, and hosting sorted</strong>
            <p class="bridge-item-desc">If you need it, I handle the technical setup so your site is live, secure, and stays that way.</p>
          </div>
        </div>
        <div class="bridge-item">
          <span class="bridge-item-icon">&#x2714;</span>
          <div>
            <strong class="bridge-item-title">One person, start to finish</strong>
            <p class="bridge-item-desc">No handoffs between a designer, a developer, and a third person you've never met. I own the whole thing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <section class="py-10 mid-cta-section">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xl font-semibold mid-cta-title mb-2">Have something you need built?</p>
      <p class="text-sm mid-cta-sub mb-6">Let's talk about what you're trying to build.</p>
      <a href="/contact" class="primary-cta-button">Work With Me</a>
    </div>
  </section>

  <!-- Who I Work With -->
  <section class="py-16 who-section">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="bridge-eyebrow">Is this for you?</span>
      <h2 class="text-2xl md:text-3xl font-bold who-title mt-3 mb-3">Who I Work With</h2>
      <p class="who-subtitle mb-10">If any of these sound like you, we should talk.</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
        <li class="who-item">
          <span class="who-check">&#x2713;</span>
          <span>Small businesses that need a custom website or internal tool built right</span>
        </li>
        <li class="who-item">
          <span class="who-check">&#x2713;</span>
          <span>Founders building a product who need a developer who can actually get it done</span>
        </li>
        <li class="who-item">
          <span class="who-check">&#x2713;</span>
          <span>Teams that need backend help, faster load times, or a site that stops breaking</span>
        </li>
        <li class="who-item">
          <span class="who-check">&#x2713;</span>
          <span>Anyone who has been burned by vague timelines and half-finished work before</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Why Me -->
  <section class="py-12 personal-intro-section">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="why-me-inner">
        <!-- Left: headline + paragraph -->
        <div class="why-me-left">
          <span class="bridge-eyebrow">Why work with me</span>
          <p class="text-2xl md:text-3xl font-semibold personal-intro-text leading-snug mt-3">
            You won't be chasing me for updates.
          </p>
          <p class="mt-4 text-base personal-intro-sub">
            I keep a small client load on purpose. Every project gets a real timeline, regular check-ins, and someone who actually sees it through.
          </p>
        </div>
        <!-- Right: bullets -->
        <ul class="why-me-bullets">
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Clear timelines and expectations from day one</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Regular updates — you'll always know where things stand</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Organized builds, not frantic last-minute scrambles</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Projects get finished and launched, not handed off half-done</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Current Focus Section -->
  <section class="py-20 section-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="bridge-eyebrow">My approach</span>
        <h2 class="text-3xl md:text-4xl font-bold section-title mt-3 mb-4">How I Work</h2>
        <p class="text-xl section-subtitle max-w-3xl mx-auto">
          I take care of everything technical so you don't have to. Most clients just want something that works and stays working. That's what I build.
        </p>
      </div>
      
      <div class="max-w-5xl mx-auto">
        <div class="focus-pill mb-8">
          <span class="focus-pill-dot" aria-hidden="true"></span>
          <p>Open for freelance work. I take projects seriously, communicate clearly, and actually finish them.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <article class="focus-card">
            <h3 class="focus-card-title mb-2">I Build. I Launch. Done.</h3>
            <p class="focus-card-copy">
              I genuinely enjoy taking a project from idea to live. You get something that works, not a prototype that still needs three more people to finish it.
            </p>
          </article>

          <article class="focus-card">
            <h3 class="focus-card-title mb-2">One Person, All of It</h3>
            <p class="focus-card-copy">
              Websites, web apps, booking tools, dashboards. I handle the technical side from front to back. No passing the buck to someone else halfway through.
            </p>
          </article>

          <article class="focus-card">
            <h3 class="focus-card-title mb-2">No Fluff, Just Results</h3>
            <p class="focus-card-copy">
              I focus on what your project actually needs, not what looks impressive on a proposal. High standards, straight communication. Your deadline is my deadline.
            </p>
          </article>
        </div>
      </div>

      <!-- Daily Build Log Link -->
      <div class="max-w-3xl mx-auto mt-8 pt-6 border-t border-[#2a2a2a]">
        <div class="flex items-center justify-center">
          <a href="https://x.com/djmartin2019" target="_blank" rel="noopener noreferrer" class="build-log-link">
            <svg class="h-4 w-4 mr-2 x-logo-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span>Daily build log</span>
            <ExternalLink class="h-3 w-3 ml-1.5 opacity-60" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-20 projects-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="bridge-eyebrow">Proof of work</span>
        <h2 class="text-3xl md:text-4xl font-bold projects-title mt-3 mb-4">Things I've Built</h2>
        <p class="text-xl projects-subtitle">Real projects, in production. Not just sitting in a GitHub repo collecting dust.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.slice(0, 3).map((project) => (
          <div class="neon-card overflow-hidden hover:shadow-neon-glow transition-all duration-300 flex flex-col">
            <div class="h-64 project-image-bg flex items-center justify-center overflow-hidden">
              <Image 
                src={project.image} 
                alt={`${project.title} project screenshot`}
                width={400}
                height={300}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xl font-semibold project-title">{project.title}</h3>
                <span class={`px-2 py-1 text-xs font-medium rounded-full status-badge status-${project.status}`}>
                  {project.status}
                </span>
              </div>
              <p class="project-description mb-4">{project.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.technologies.slice(0, 3).map((tech) => (
                  <span class="px-2 py-1 tech-tag text-xs rounded">{tech}</span>
                ))}
              </div>
              <div class="flex flex-col sm:flex-row gap-3 mt-auto">
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="primary-cta-button flex items-center justify-center">
                    <ExternalLink class="h-4 w-4 mr-2" />
                    View Website
                  </a>
                )}
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="secondary-cta-button flex items-center justify-center">
                    <Github class="h-4 w-4 mr-2" />
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/projects" class="neon-button">
          View All Projects
        </a>
      </div>
    </div>
  </section>

  <!-- Hosting & Deployment Section -->
  <section class="hosting-section py-20">
    <div class="absolute top-0 left-0 right-0 h-px hosting-divider-top"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="hosting-eyebrow">
          <Folder class="h-4 w-4 mr-2" />
          Hosting & Deployment
        </span>
        <h2 class="text-3xl md:text-4xl font-bold hosting-title mt-4 mb-4">
          I Handle Hosting Too
        </h2>
        <p class="text-xl hosting-subtitle max-w-2xl mx-auto">
          Most developers hand you a finished website and disappear. I can also host your project, set up your domain, and keep it running. No mystery bills from third-party platforms, no "that's not my problem." If you need it, I've got it covered.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <article class="focus-card">
          <h3 class="focus-card-title mb-2">Apps Stay Separate</h3>
          <p class="focus-card-copy">
            Each project runs in its own environment. One site going down doesn't affect another, and updates happen cleanly without breaking anything else.
          </p>
        </article>

        <article class="focus-card">
          <h3 class="focus-card-title mb-2">Works With Your Tech</h3>
          <p class="focus-card-copy">
            Whatever your project is built on, I can host it. I'm not locked into one platform or one way of doing things. It runs on what makes sense for your project.
          </p>
        </article>

        <article class="focus-card">
          <h3 class="focus-card-title mb-2">Domain, Security & Uptime</h3>
          <p class="focus-card-copy">
            I handle domain setup, security certificates, and keeping things live. You don't need to know what any of that means. That's the point.
          </p>
        </article>
      </div>

      <div class="text-center space-y-4">
        <a href="https://djm-apps.com/" target="_blank" rel="noopener noreferrer" class="hosting-link">
          View Live Hosting Environment
          <ExternalLink class="h-4 w-4 ml-2" />
        </a>
        <p class="text-sm hosting-subtitle">Curious about the technical details behind the scenes? I write about it on the <a href="/blog" class="underline opacity-80 hover:opacity-100">Build Log</a>.</p>
      </div>
    </div>
  </section>

  <!-- Recent Writing -->
  <section class="py-20 blog-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="bridge-eyebrow">Writing</span>
        <h2 class="text-3xl md:text-4xl font-bold blog-title mt-3 mb-4">Build Log</h2>
        <p class="text-xl blog-subtitle">What I'm thinking about, building, and occasionally complaining about</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {recentPosts.slice(0, 2).map((post) => (
          <article class="neon-card overflow-hidden hover:shadow-neon-glow transition-all duration-300 flex flex-col">
            <div class="h-64 project-image-bg flex items-center justify-center overflow-hidden">
              <Image 
                src={post.image || "/assets/og-default.png"} 
                alt={post.title}
                width={400}
                height={300}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center text-sm blog-meta mb-2">
                <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span class="mx-2">•</span>
                <span>{post.readTime} min read</span>
              </div>
              <h3 class="text-xl font-semibold blog-post-title mb-3">{post.title}</h3>
              <p class="blog-post-description mb-4">{post.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="px-2 py-1 blog-tag text-xs rounded">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}`} class="blog-link mt-auto">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/blog" class="neon-button">
          Read the Build Log
        </a>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="closing-cta-bg py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold closing-cta-title mb-4">
        Let's skip the small talk.
      </h2>
      <p class="text-xl closing-cta-subtitle mb-10 max-w-xl mx-auto">
        You have a project. I build things. Whether you're a business, a startup, or another developer who needs a collaborator, send me a message and let's figure out if we're a good fit.
      </p>
      <a href="/contact" class="primary-cta-button text-lg px-8 py-4">
        Get In Touch
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .tech-stack-label {
    color: var(--text-secondary);
    opacity: 0.65;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    min-width: 5.5rem;
  }

  .tech-hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(0, 212, 255, 0.06);
    border: 1px solid rgba(0, 212, 255, 0.2);
    color: var(--text-secondary);
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
  }

  .tech-hero-badge:hover {
    background: rgba(0, 212, 255, 0.12);
    border-color: rgba(0, 212, 255, 0.4);
    color: #00d4ff;
  }

  html.light .tech-hero-badge {
    background: rgba(0, 212, 255, 0.08);
    border-color: rgba(0, 212, 255, 0.25);
    color: #334155;
  }

  html.light .tech-hero-badge:hover {
    background: rgba(0, 212, 255, 0.15);
    border-color: rgba(0, 212, 255, 0.45);
    color: #0099cc;
  }

  .hero-bg {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    position: relative;
  }
  
  html.light .hero-bg {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.9) 50%, rgba(240, 248, 255, 0.85) 100%);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  
  .hero-bg-elements {
    pointer-events: none;
  }
  
  .hero-bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.04) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
  }
  
  html.light .hero-bg-gradient {
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.02) 0%, transparent 50%);
  }
  
  .hero-bg-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
    background-size: 20px 20px;
    opacity: 0.2;
  }
  
  html.light .hero-bg-pattern {
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.05) 1px, transparent 0);
    opacity: 0.15;
  }
  
  .hero-title {
    color: var(--text-primary);
  }
  
  .hero-subtitle {
    color: var(--text-secondary);
  }
  
  html.light .hero-title {
    color: rgba(15, 23, 42, 0.8);
    font-weight: 700;
  }
  
  html.light .hero-subtitle {
    color: rgba(71, 85, 105, 0.7);
    font-weight: 500;
  }
  
  /* Status Tag */
  .status-tag {
    background-color: rgba(0, 212, 255, 0.2);
    border: 1px solid rgba(0, 212, 255, 0.4);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    color: #ffffff;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.2);
  }
  
  html.light .status-tag {
    background-color: rgba(0, 212, 255, 0.8);
    border-color: rgba(0, 212, 255, 0.9);
    color: #000000;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.2);
  }
  
  /* CTA Buttons */
  .primary-cta-button {
    background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
    color: #0a0a0a;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 8px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.2);
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .primary-cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 212, 255, 0.4), 0 0 20px rgba(0, 212, 255, 0.3);
    background: linear-gradient(135deg, #33dfff 0%, #00d4ff 100%);
  }
  
  .secondary-cta-button {
    background-color: transparent;
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: 2px solid #00d4ff;
