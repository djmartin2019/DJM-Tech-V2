  /* Project Feature Cards */
  .pf-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .pf-card:hover {
    border-color: rgba(0, 212, 255, 0.25);
    box-shadow: 0 0 24px rgba(0, 212, 255, 0.07);
  }

  .pf-card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #0a0a14;
    flex-shrink: 0;
  }

  .pf-card-image img {
    transition: transform 0.3s ease;
  }

  .pf-card:hover .pf-card-image img {
    transform: scale(1.03);
  }

  .pf-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.55) 100%);
    pointer-events: none;
  }

  .pf-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem 1.5rem 1.5rem;
    gap: 0.5rem;
  }

  .pf-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pf-card-title {
    font-size: 1rem;
    font-weight: 650;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .pf-status-badge {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    white-space: nowrap;
    margin-top: 0.1rem;
  }

  .pf-status-completed {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.25);
  }

  .pf-status-current {
    background: rgba(0, 212, 255, 0.1);
    color: #00d4ff;
    border: 1px solid rgba(0, 212, 255, 0.25);
  }

  .pf-card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
    flex: 1;
  }

  .pf-card-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .pf-btn-primary {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.38rem 0.85rem;
    border-radius: 0.375rem;
    background: rgba(0, 212, 255, 0.12);
    color: #00d4ff;
    border: 1px solid rgba(0, 212, 255, 0.35);
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .pf-btn-primary:hover {
    background: rgba(0, 212, 255, 0.2);
    border-color: rgba(0, 212, 255, 0.6);
  }

  .pf-btn-secondary {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.38rem 0.85rem;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .pf-btn-secondary:hover {
    color: var(--text-primary);
    border-color: rgba(0, 212, 255, 0.3);
  }

