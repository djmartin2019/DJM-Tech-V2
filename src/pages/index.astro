---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { Code, Folder, Mail, Star, ExternalLink, Github } from 'lucide-astro';
import { getFeaturedProjects } from '../data/projects';
import { getRecentPosts } from '../data/blog';

const featuredProjects = getFeaturedProjects();
const recentPosts = await getRecentPosts(3);
---

<Layout title="DJM Tech - Modern Websites. Zero Bloat. Built for Speed.">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative hero-bg py-20 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div class="space-y-8 text-center lg:text-left">
          <!-- Main Heading -->
          <h1 class="text-5xl md:text-6xl font-bold hero-title leading-tight">
            Modern Websites. Zero Bloat. <br />
            <span class="neon-glow">Built for Speed.</span>
          </h1>
          
          <!-- Description -->
          <p class="text-xl hero-subtitle max-w-2xl lg:max-w-none mx-auto lg:mx-0">
            Fast, real-world site stacks built with Astro, Contentful, and Cloudflare.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/stacks" class="primary-cta-button">
              Explore the Stack
            </a>
          </div>
        </div>
        
        <!-- Right Content - Image -->
        <div class="relative hidden lg:block">
          <div class="hero-image-container">
            <img 
              src="/assets/djm-image.png" 
              alt="DJM Tech - Modern Websites Built for Speed" 
              class="hero-image"
            />
            <div class="hero-image-glow"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Background Elements -->
    <div class="absolute inset-0 hero-bg-elements">
      <div class="hero-bg-gradient"></div>
      <div class="hero-bg-pattern"></div>
    </div>
  </section>

  <!-- Available Stack Section -->
  <section class="py-24 lg:py-32 section-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        <!-- Left Column: Content -->
        <div class="space-y-8">
          <!-- Section Label -->
          <div class="inline-flex items-center space-x-2 mb-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-[#00d4ff] opacity-80">Available Stack</span>
          </div>

          <!-- Stack Name -->
          <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold section-title leading-tight tracking-tight">
            BareStack
          </h2>

          <!-- Tagline -->
          <p class="text-xl md:text-2xl section-subtitle leading-relaxed max-w-xl">
            The fast, headless site stack with no extra baggage. Not even React.
          </p>

          <!-- Tech Stack Pills -->
          <div class="flex flex-wrap gap-2 pt-2">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-[#00d4ff]/10 text-[#00d4ff] border border-[#00d4ff]/20">
              Astro
            </span>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-[#00d4ff]/10 text-[#00d4ff] border border-[#00d4ff]/20">
              Cloudflare
            </span>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-[#00d4ff]/10 text-[#00d4ff] border border-[#00d4ff]/20">
              Contentful
            </span>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-[#00d4ff]/10 text-[#00d4ff] border border-[#00d4ff]/20">
              Markdown
            </span>
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-[#00d4ff]/10 text-[#00d4ff] border border-[#00d4ff]/20">
              Resend
            </span>
          </div>

          <!-- Features List -->
          <div class="space-y-4 pt-4">
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#00d4ff]/20 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-[#00d4ff]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="section-subtitle text-base">Lightning-fast deploys</span>
            </div>
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#00d4ff]/20 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-[#00d4ff]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="section-subtitle text-base">Full CMS support</span>
            </div>
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#00d4ff]/20 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-[#00d4ff]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="section-subtitle text-base">100 Lighthouse score</span>
            </div>
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#00d4ff]/20 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-[#00d4ff]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="section-subtitle text-base">Free hosting on Cloudflare</span>
            </div>
          </div>

          <!-- CTA -->
          <div class="pt-6 space-y-2">
            <a href="/stacks" class="primary-cta-button inline-block">
              Use this stack
            </a>
            <p class="text-sm section-subtitle opacity-70">
              No React. No config. Just deploy.
            </p>
          </div>
        </div>

        <!-- Right Column: Visual -->
        <div class="relative hidden lg:block">
          <div class="relative">
            <!-- Mock Browser Frame -->
            <div class="neon-card overflow-hidden backdrop-blur-sm bg-[#0a0a0a]/50 border border-[#2a2a2a] rounded-lg shadow-2xl">
              <!-- Browser Header -->
              <div class="flex items-center space-x-2 px-4 py-3 bg-[#111111] border-b border-[#2a2a2a]">
                <div class="flex space-x-1.5">
                  <div class="w-3 h-3 rounded-full bg-[#2a2a2a]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#2a2a2a]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#2a2a2a]"></div>
                </div>
                <div class="flex-1 mx-4">
                  <div class="h-6 bg-[#1a1a1a] rounded border border-[#2a2a2a] flex items-center px-3">
                    <span class="text-xs text-[#a3a3a3]">barestack.dev</span>
                  </div>
                </div>
              </div>
              
              <!-- Browser Content -->
              <div class="p-8 bg-gradient-to-br from-[#0a0a0a] via-[#111111] to-[#0a0a0a]">
                <!-- Code Preview -->
                <div class="space-y-4">
                  <div class="flex items-center space-x-2 mb-4">
                    <div class="w-2 h-2 rounded-full bg-[#00d4ff]"></div>
                    <span class="text-xs text-[#a3a3a3] font-mono">lib/contentful.ts</span>
                  </div>
                  <div class="space-y-2 font-mono text-sm leading-relaxed">
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">1</span>
                      <span class="text-[#c792ea]">import</span>
                      <span class="text-[#e5e5e5]"> {'{'}{' '}createClient{' '}{'}'} </span>
                      <span class="text-[#c792ea]">from</span>
                      <span class="text-[#c3e88d]"> 'contentful'</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">2</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">3</span>
                      <span class="text-[#82aaff]">const</span>
                      <span class="text-[#e5e5e5]"> client = </span>
                      <span class="text-[#f78c6c]">createClient</span><span class="text-[#e5e5e5]">{'('}{'{'}</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">4</span>
                      <span class="text-[#e5e5e5]">  space: </span>
                      <span class="text-[#82aaff]">import</span><span class="text-[#e5e5e5]">.</span><span class="text-[#82aaff]">meta</span><span class="text-[#e5e5e5]">.</span><span class="text-[#82aaff]">env</span><span class="text-[#e5e5e5]">.</span><span class="text-[#c3e88d]">CONTENTFUL_SPACE_ID</span><span class="text-[#e5e5e5]">,</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">5</span>
                      <span class="text-[#e5e5e5]">  accessToken: </span>
                      <span class="text-[#82aaff]">import</span><span class="text-[#e5e5e5]">.</span><span class="text-[#82aaff]">meta</span><span class="text-[#e5e5e5]">.</span><span class="text-[#82aaff]">env</span><span class="text-[#e5e5e5]">.</span><span class="text-[#c3e88d]">CONTENTFUL_ACCESS_TOKEN</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">6</span>
                      <span class="text-[#e5e5e5]">{'}'}{')'}</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">7</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">8</span>
                      <span class="text-[#82aaff]">const</span>
                      <span class="text-[#e5e5e5]"> {'{'}{' '}items{' '}{'}'} = </span>
                      <span class="text-[#82aaff]">await</span>
                      <span class="text-[#e5e5e5]"> client.</span><span class="text-[#f78c6c]">getEntries</span><span class="text-[#e5e5e5]">{'('}{'{'}</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">9</span>
                      <span class="text-[#e5e5e5]">  content_type: </span>
                      <span class="text-[#c3e88d]">'blogPost'</span>
                    </div>
                    <div class="flex">
                      <span class="text-[#64748b] w-8 text-right pr-4 select-none">10</span>
                      <span class="text-[#e5e5e5]">{'}'}{')'}</span>
                    </div>
                  </div>
                  
                  <!-- Performance Indicator -->
                  <div class="mt-8 pt-6 border-t border-[#2a2a2a]">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-xs text-[#a3a3a3]">Performance</span>
                      <span class="text-xs font-semibold text-[#00d4ff]">100</span>
                    </div>
                    <div class="h-2 bg-[#1a1a1a] rounded-full overflow-hidden">
                      <div class="h-full bg-gradient-to-r from-[#00d4ff] to-[#0099cc] rounded-full" style="width: 100%"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Glow Effect -->
            <div class="absolute -inset-1 bg-gradient-to-r from-[#00d4ff]/20 via-[#0099cc]/20 to-[#00d4ff]/20 rounded-lg blur-xl opacity-50 -z-10"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="py-24 lg:py-32 roadmap-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center space-x-2 mb-3">
          <span class="text-xs font-semibold uppercase tracking-wider text-[#f59e0b] opacity-80">Roadmap</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold roadmap-title mb-4">Coming Soon</h2>
        <h3 class="text-2xl md:text-3xl font-semibold roadmap-title mb-6">More Stacks on the Way</h3>
        <p class="text-lg md:text-xl roadmap-subtitle max-w-2xl mx-auto leading-relaxed">
          I'm working on two new stack flavors designed for speed, interactivity, and minimal suffering:
        </p>
      </div>

      <!-- Stack Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto mb-16">
        <!-- QwikStack Card -->
        <div class="roadmap-card group">
          <div class="p-8 lg:p-10 flex flex-col h-full">
            <div class="mb-6">
              <h4 class="text-3xl md:text-4xl font-bold roadmap-card-title mb-4">QwikStack</h4>
              <p class="roadmap-card-description leading-relaxed">
                For interactive apps with instant-loading components. Zero hydration overhead. Maximum performance.
              </p>
            </div>
            
            <div class="mt-auto pt-6">
              <div class="inline-flex items-center px-5 py-2.5 rounded-full text-sm font-semibold roadmap-badge border-2">
                <span class="w-2 h-2 rounded-full bg-[#f59e0b] mr-2.5 animate-pulse"></span>
                Coming Soon
              </div>
            </div>
          </div>
        </div>

        <!-- HTMXStack Card -->
        <div class="roadmap-card group">
          <div class="p-8 lg:p-10 flex flex-col h-full">
            <div class="mb-6">
              <h4 class="text-3xl md:text-4xl font-bold roadmap-card-title mb-4">HTMXStack</h4>
              <p class="roadmap-card-description leading-relaxed">
                For minimal-JS lovers who still want dynamic sites. HTML-first. Progressive enhancement. Zero bloat.
              </p>
            </div>
            
            <div class="mt-auto pt-6">
              <div class="inline-flex items-center px-5 py-2.5 rounded-full text-sm font-semibold roadmap-badge border-2">
                <span class="w-2 h-2 rounded-full bg-[#f59e0b] mr-2.5 animate-pulse"></span>
                Coming Soon
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footnote -->
      <div class="text-center pt-8 border-t border-[#2a2a2a] max-w-2xl mx-auto">
        <p class="text-xs md:text-sm roadmap-footnote">
          All stacks avoid React by design.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-20 projects-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold projects-title mb-4">Featured Projects</h2>
        <p class="text-xl projects-subtitle">Some of my recent work and ongoing projects</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.slice(0, 3).map((project) => (
          <div class="neon-card overflow-hidden hover:shadow-neon-glow transition-all duration-300 flex flex-col">
            <div class="h-64 project-image-bg flex items-center justify-center overflow-hidden">
              <Image 
                src={project.image} 
                alt={`${project.title} project screenshot`}
                width={400}
                height={300}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xl font-semibold project-title">{project.title}</h3>
                <span class={`px-2 py-1 text-xs font-medium rounded-full status-badge status-${project.status}`}>
                  {project.status}
                </span>
              </div>
              <p class="project-description mb-4">{project.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.technologies.slice(0, 3).map((tech) => (
                  <span class="px-2 py-1 tech-tag text-xs rounded">{tech}</span>
                ))}
              </div>
              <div class="flex flex-col sm:flex-row gap-3 mt-auto">
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="primary-cta-button flex items-center justify-center">
                    <ExternalLink class="h-4 w-4 mr-2" />
                    View Website
                  </a>
                )}
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="secondary-cta-button flex items-center justify-center">
                    <Github class="h-4 w-4 mr-2" />
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/projects" class="neon-button">
          View All Projects
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Build Logs -->
  <section class="py-20 blog-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold blog-title mb-4">Latest Build Logs</h2>
        <p class="text-xl blog-subtitle">Notes, experiments, and thoughts on building DJM Tech</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recentPosts.slice(0, 3).map((post) => (
          <article class="neon-card overflow-hidden hover:shadow-neon-glow transition-all duration-300 flex flex-col">
            <div class="h-48 blog-image-bg flex items-center justify-center overflow-hidden">
              <Image 
                src={post.image || "/assets/og-default.png"} 
                alt={post.title}
                width={400}
                height={192}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center text-sm blog-meta mb-2">
                <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <span class="mx-2">•</span>
                <span>{post.readTime} min read</span>
              </div>
              <h3 class="text-xl font-semibold blog-post-title mb-3">{post.title}</h3>
              <p class="blog-post-description mb-4">{post.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="px-2 py-1 blog-tag text-xs rounded">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}`} class="blog-link mt-auto">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/blog" class="neon-button">
          View All Posts
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 cta-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold cta-title mb-4">Let's Chat</h2>
      <p class="text-xl cta-subtitle mb-8 max-w-2xl mx-auto">
        Have a project in mind or just want to talk tech, music, or startups? 
        Drop a message and let's make something epic.
      </p>
      <a href="/contact" class="cta-button inline-flex items-center">
        <Mail class="h-5 w-5 mr-2" />
        Send Message
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-bg {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    position: relative;
  }
  
  html.light .hero-bg {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.9) 50%, rgba(240, 248, 255, 0.85) 100%);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  
  .hero-bg-elements {
    pointer-events: none;
  }
  
  .hero-bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.04) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
  }
  
  html.light .hero-bg-gradient {
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.02) 0%, transparent 50%);
  }
  
  .hero-bg-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
    background-size: 20px 20px;
    opacity: 0.2;
  }
  
  html.light .hero-bg-pattern {
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.05) 1px, transparent 0);
    opacity: 0.15;
  }
  
  .hero-title {
    color: var(--text-primary);
  }
  
  .hero-subtitle {
    color: var(--text-secondary);
  }
  
  html.light .hero-title {
    color: rgba(15, 23, 42, 0.8);
    font-weight: 700;
  }
  
  html.light .hero-subtitle {
    color: rgba(71, 85, 105, 0.7);
    font-weight: 500;
  }
  
  /* Status Tag */
  .status-tag {
    background-color: rgba(0, 212, 255, 0.2);
    border: 1px solid rgba(0, 212, 255, 0.4);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    color: #ffffff;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.2);
  }
  
  html.light .status-tag {
    background-color: rgba(0, 212, 255, 0.8);
    border-color: rgba(0, 212, 255, 0.9);
    color: #000000;
    backdrop-filter: blur(10px);
