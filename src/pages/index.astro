---
import '../styles/home.css';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/home/HeroSection.astro';
import AboutSection from '../components/home/AboutSection.astro';
import FeaturedProjectsSection from '../components/home/FeaturedProjectsSection.astro';
import InfrastructureLabSection from '../components/home/InfrastructureLabSection.astro';
import TechnicalWritingSection from '../components/home/TechnicalWritingSection.astro';

const title = 'David Martin | Backend & Platform Engineer';
const description =
  'Backend and platform engineer building operational software, developer infrastructure, and scalable systems with TypeScript, Postgres, Docker, and cloud platforms.';
const canonical = 'https://djmtech.dev/';
---

<Layout {title} {description} canonical={canonical}>
  <Header />

  <main>
    <HeroSection />
    <AboutSection />
    <FeaturedProjectsSection />
    <InfrastructureLabSection />
    <TechnicalWritingSection />
  </main>

  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'David Martin',
  jobTitle: 'Backend & Platform Engineer',
  url: canonical,
  description,
  sameAs: ['https://github.com/djmartin2019'],
})} />
