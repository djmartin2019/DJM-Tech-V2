---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { ExternalLink, Github } from 'lucide-astro';
import { getFeaturedProjects } from '../data/projects';

const featuredProjects = getFeaturedProjects();
---

<Layout title="David Martin - Developer & Freelance Engineer">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative hero-bg py-20 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div class="space-y-8 text-center lg:text-left">
          <!-- Main Heading -->
          <h1 class="text-5xl md:text-6xl font-bold hero-title leading-tight">
            David Martin <br />
            <span class="neon-glow">I Build Websites and Tools for Businesses</span>
          </h1>
          
          <!-- Description -->
          <p class="text-xl hero-subtitle max-w-2xl lg:max-w-none mx-auto lg:mx-0">
            Clear timelines. Clean builds. No chasing for updates.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="/contact" class="primary-cta-button">
              Start a Project
            </a>
            <a href="/projects" class="secondary-cta-button">
              View Projects
            </a>
          </div>

        </div>
        
        <!-- Right Content - Headshot -->
        <div class="relative hidden lg:block">
          <div class="hero-image-container">
            <div class="hero-portrait-ring">
              <img 
                src="/assets/about-me-photo.jpeg" 
                alt="David Martin - Web Developer and Freelance Engineer" 
                class="hero-portrait"
              />
            </div>
            <div class="hero-image-glow"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Background Elements -->
    <div class="absolute inset-0 hero-bg-elements">
      <div class="hero-bg-gradient"></div>
      <div class="hero-bg-pattern"></div>
    </div>
  </section>

  <!-- Projects -->
  <section class="py-16 projects-bg">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="bridge-eyebrow">Proof of work</span>
        <h2 class="text-3xl font-bold projects-title mt-3 mb-3">Things I've Built</h2>
        <p class="projects-subtitle">Real projects, for real clients. Here's the kind of work I take on.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.slice(0, 3).map((project) => (
          <div class="pf-card">
            <div class="pf-card-image">
              <Image
                src={project.image}
                alt={project.title}
                width={480}
                height={270}
                class="w-full h-full object-cover"
              />
              <div class="pf-card-image-overlay" />
            </div>
            <div class="pf-card-body">
              <div class="pf-card-header">
                <h3 class="pf-card-title">{project.title}</h3>
                <span class={`pf-status-badge pf-status-${project.status}`}>
                  {project.status}
                </span>
              </div>
              <p class="pf-card-desc">{project.description}</p>
              <div class="pf-card-actions">
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="pf-btn-primary">
                    View Project <ExternalLink class="h-3.5 w-3.5 ml-1 inline" />
                  </a>
                )}
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="pf-btn-secondary">
                    <Github class="h-3.5 w-3.5 mr-1 inline" /> GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/projects" class="neon-button">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- Why Me -->
  <section class="py-12 personal-intro-section">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="why-me-inner">
        <div class="why-me-left">
          <span class="bridge-eyebrow">Why work with me</span>
          <p class="text-2xl md:text-3xl font-semibold personal-intro-text leading-snug mt-3">
            You won't be chasing me for updates.
          </p>
          <p class="mt-4 text-base personal-intro-sub">
            I keep a small client load on purpose. Real timelines, regular check-ins, and someone who actually finishes what they start.
          </p>
        </div>
        <ul class="why-me-bullets">
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Clear timelines from day one</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Regular updates so you always know where things stand</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Organized, consistent execution</span>
          </li>
          <li class="why-me-item">
            <span class="why-me-check">&#x2714;</span>
            <span>Projects get finished, not abandoned</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-16 bridge-section">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="what-i-do-inner">
        <div class="what-i-do-left">
          <span class="bridge-eyebrow">What I do</span>
          <h2 class="text-3xl md:text-4xl font-bold bridge-title mt-3 mb-4">
            Ideas into things that work.
          </h2>
          <p class="text-lg bridge-subtitle">
            Whether it's a website, a booking system, or a custom tool, I build it properly and see it through to launch.
          </p>
          <p class="mt-5 text-sm bridge-subtitle" style="opacity: 0.65;">
            AI can help you get started. I make sure what you build actually works.
          </p>
        </div>
        <ul class="what-i-do-list">
          <li class="bridge-item">
            <span class="bridge-item-icon">&#x2714;</span>
            <div>
              <strong class="bridge-item-title">Fix builds that are messy or half-finished</strong>
              <p class="bridge-item-desc">If a previous developer left things broken, I can take over, clean it up, and move forward.</p>
            </div>
          </li>
          <li class="bridge-item">
            <span class="bridge-item-icon">&#x2714;</span>
            <div>
              <strong class="bridge-item-title">Turn rough ideas into working products</strong>
              <p class="bridge-item-desc">From "I have an idea" to something live that does what it's supposed to.</p>
            </div>
          </li>
          <li class="bridge-item">
            <span class="bridge-item-icon">&#x2714;</span>
            <div>
              <strong class="bridge-item-title">One person, start to finish</strong>
              <p class="bridge-item-desc">No handoffs. I own the whole thing and see it through.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="closing-cta-bg py-20">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold closing-cta-title mb-3">
        Have something you need built?
      </h2>
      <p class="text-lg closing-cta-subtitle mb-8">{" "}</p>
      <a href="/contact" class="primary-cta-button text-lg px-8 py-4">
        Let's Connect
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .tech-stack-label {
    color: var(--text-secondary);
    opacity: 0.65;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    min-width: 5.5rem;
  }

  .tech-hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(0, 212, 255, 0.06);
    border: 1px solid rgba(0, 212, 255, 0.2);
    color: var(--text-secondary);
    letter-spacing: 0.01em;
    transition: all 0.2s ease;
  }

  .tech-hero-badge:hover {
    background: rgba(0, 212, 255, 0.12);
    border-color: rgba(0, 212, 255, 0.4);
    color: #00d4ff;
  }

  html.light .tech-hero-badge {
    background: rgba(0, 212, 255, 0.08);
    border-color: rgba(0, 212, 255, 0.25);
    color: #334155;
  }

  html.light .tech-hero-badge:hover {
    background: rgba(0, 212, 255, 0.15);
    border-color: rgba(0, 212, 255, 0.45);
    color: #0099cc;
  }

  .hero-bg {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    position: relative;
  }
  
  html.light .hero-bg {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.9) 50%, rgba(240, 248, 255, 0.85) 100%);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  
  .hero-bg-elements {
    pointer-events: none;
  }
  
  .hero-bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.04) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
  }
  
  html.light .hero-bg-gradient {
    background: radial-gradient(circle at 30% 20%, rgba(0, 212, 255, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(0, 212, 255, 0.02) 0%, transparent 50%);
  }
  
  .hero-bg-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.08) 1px, transparent 0);
    background-size: 20px 20px;
    opacity: 0.2;
  }
  
  html.light .hero-bg-pattern {
    background-image: 
      radial-gradient(circle at 1px 1px, rgba(0, 212, 255, 0.05) 1px, transparent 0);
    opacity: 0.15;
  }
  
  .hero-title {
    color: var(--text-primary);
  }
  
  .hero-subtitle {
    color: var(--text-secondary);
  }
  
  html.light .hero-title {
    color: rgba(15, 23, 42, 0.8);
    font-weight: 700;
  }
  
  html.light .hero-subtitle {
    color: rgba(71, 85, 105, 0.7);
    font-weight: 500;
  }
  
  /* Status Tag */
  .status-tag {
    background-color: rgba(0, 212, 255, 0.2);
    border: 1px solid rgba(0, 212, 255, 0.4);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    color: #ffffff;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.2);
  }
  
  html.light .status-tag {
    background-color: rgba(0, 212, 255, 0.8);
    border-color: rgba(0, 212, 255, 0.9);
    color: #000000;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.2);
  }
  
  /* CTA Buttons */
  .primary-cta-button {
    background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
    color: #0a0a0a;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 8px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.2);
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .primary-cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 212, 255, 0.4), 0 0 20px rgba(0, 212, 255, 0.3);
    background: linear-gradient(135deg, #33dfff 0%, #00d4ff 100%);
  }
  
  .secondary-cta-button {
    background-color: transparent;
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    border: 2px solid #00d4ff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
  }
  
  .secondary-cta-button:hover {
    background-color: #00d4ff;
    color: #0a0a0a;
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 212, 255, 0.3), 0 0 20px rgba(0, 212, 255, 0.2);
  }
  
  html.light .secondary-cta-button {
    color: #00d4ff;
    border-color: #00d4ff;
  }
  
  html.light .secondary-cta-button:hover {
    background-color: #00d4ff;
    color: #ffffff;
  }
  
  /* Hero Image */
  .hero-image-container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Portrait ring: neon border with subtle outer glow */
  .hero-portrait-ring {
    position: relative;
    z-index: 2;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.7) 0%, rgba(0, 212, 255, 0.15) 50%, rgba(0, 212, 255, 0.5) 100%);
    box-shadow:
      0 0 0 1px rgba(0, 212, 255, 0.12),
      0 0 32px rgba(0, 212, 255, 0.2),
      0 0 64px rgba(0, 212, 255, 0.08);
    transition: box-shadow 0.3s ease;
  }

  .hero-portrait-ring:hover {
    box-shadow:
      0 0 0 1px rgba(0, 212, 255, 0.2),
      0 0 40px rgba(0, 212, 255, 0.3),
      0 0 80px rgba(0, 212, 255, 0.12);
  }

  .hero-portrait {
    width: 360px;
    height: 360px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.3s ease;
  }

  .hero-portrait-ring:hover .hero-portrait {
    transform: scale(1.02);
  }

  .hero-image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 110%;
    height: 110%;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.1) 0%, transparent 65%);
    border-radius: 50%;
    z-index: 1;
    animation: pulse-glow 4s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% {
      opacity: 0.2;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.4;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  
  html.light .hero-image-glow {
    background: radial-gradient(circle, rgba(0, 212, 255, 0.07) 0%, transparent 65%);
  }

  html.light .hero-portrait-ring {
    background: linear-gradient(135deg, rgba(0, 153, 204, 0.8) 0%, rgba(0, 153, 204, 0.2) 50%, rgba(0, 153, 204, 0.6) 100%);
    box-shadow:
      0 0 0 1px rgba(0, 153, 204, 0.15),
      0 0 24px rgba(0, 153, 204, 0.15),
      0 0 48px rgba(0, 153, 204, 0.06);
  }

  html.light .hero-portrait-ring:hover {
    box-shadow:
      0 0 0 1px rgba(0, 153, 204, 0.25),
      0 0 32px rgba(0, 153, 204, 0.25),
      0 0 64px rgba(0, 153, 204, 0.1);
  }
  
  .secondary-button {
    color: var(--accent-color);
  }
  
  .secondary-button:hover {
    background-color: var(--accent-color);
    color: var(--bg-primary);
  }
  
  .code-text {
    color: var(--text-primary);
  }
  
  html.light .code-text {
    color: #0f172a;
  }
  
  .section-bg {
    background-color: var(--bg-secondary);
  }
  
  .section-title {
    color: var(--text-primary);
  }
  
  .section-subtitle {
    color: var(--text-secondary);
  }
  
  /* Current Focus Styles */
  .focus-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    background-color: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.24);
    border-radius: 0.75rem;
    padding: 0.85rem 1rem;
    color: var(--text-primary);
    font-weight: 600;
    text-align: center;
  }

  .focus-pill-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background-color: #00d4ff;
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.6);
    flex-shrink: 0;
  }

  .focus-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0.85rem;
    padding: 1rem;
    transition: all 0.25s ease;
  }

  .focus-card:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 212, 255, 0.35);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(0, 212, 255, 0.12);
  }

  .focus-card-title {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 700;
  }

  .focus-card-copy {
    color: var(--text-secondary);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  html.light .focus-pill {
    background-color: rgba(0, 212, 255, 0.1);
    border-color: rgba(0, 212, 255, 0.3);
  }

  html.light .focus-card {
    background: #ffffff;
    border-color: #dbe3ea;
  }

  html.light .focus-card:hover {
    box-shadow: 0 8px 20px rgba(2, 8, 20, 0.08), 0 0 0 1px rgba(0, 212, 255, 0.16);
  }
  
  .build-log-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background-color: rgba(0, 212, 255, 0.05);
    border: 1px solid rgba(0, 212, 255, 0.15);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .x-logo-icon {
    color: currentColor;
    flex-shrink: 0;
  }
  
  .build-log-link:hover {
    color: #00d4ff;
    background-color: rgba(0, 212, 255, 0.1);
    border-color: rgba(0, 212, 255, 0.3);
    transform: translateY(-1px);
  }
  
  .build-log-link:hover .x-logo-icon {
    color: #00d4ff;
  }
  
  html.light .build-log-link {
    background-color: rgba(0, 212, 255, 0.08);
    border-color: rgba(0, 212, 255, 0.2);
  }
  
  html.light .build-log-link:hover {
    background-color: rgba(0, 212, 255, 0.12);
  }
  
  .accent-icon {
    color: var(--accent-color);
  }
  
  .tech-label {
    color: var(--text-primary);
  }

  .skill-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    width: 3rem;
    margin: 0 auto;
    transition: all 0.3s ease;
  }

  .skill-icon {
    transition: all 0.3s ease;
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.3));
  }

  .group:hover .skill-icon-container {
    transform: scale(1.1);
  }

  .group:hover .skill-icon {
    filter: drop-shadow(0 0 15px rgba(0, 212, 255, 0.4)) drop-shadow(0 0 25px rgba(0, 212, 255, 0.2));
    transform: scale(1.05);
  }

  html.light .skill-icon {
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.2));
  }

  html.light .group:hover .skill-icon {
    filter: drop-shadow(0 0 15px rgba(0, 212, 255, 0.4)) drop-shadow(0 0 25px rgba(0, 212, 255, 0.2));
  }
  
  /* Shared eyebrow label */
  .bridge-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #00d4ff;
    opacity: 0.85;
  }

  html.light .bridge-eyebrow {
    color: #0077a8;
    opacity: 1;
  }

  /* What I Do — 2-col layout */
  .what-i-do-inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .what-i-do-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .what-i-do-inner {
      flex-direction: row;
      align-items: flex-start;
      gap: 4rem;
    }
    .what-i-do-left {
      flex: 0 0 42%;
    }
    .what-i-do-list {
      flex: 1 1 0;
      padding-top: 0.5rem;
    }
  }

  /* Project row list */
  .project-list {
    border-top: 1px solid var(--border-color);
  }

  .project-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
  }

  .project-row-info {
    flex: 1 1 0;
    min-width: 0;
  }

  .project-row-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .project-row-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .project-row-links {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .project-row-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    font-weight: 600;
    color: #00d4ff;
    text-decoration: none;
    border: 1px solid rgba(0, 212, 255, 0.3);
    border-radius: 0.375rem;
    padding: 0.28rem 0.7rem;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .project-row-link:hover {
    background: rgba(0, 212, 255, 0.1);
    border-color: rgba(0, 212, 255, 0.55);
  }

  .project-row-link.secondary {
    color: var(--text-secondary);
    border-color: var(--border-color);
  }

